# .env.example — Kerno Compliance Copilot
#
# Copy this file to .env and fill in real values before running the application.
# Never commit .env — it is excluded by .gitignore.
#
# ──────────────────────────────────────────────────────────────────────────────
# DEV SETUP (one-time, local PostgreSQL)
# ──────────────────────────────────────────────────────────────────────────────
#
# 1. Install PostgreSQL if not already installed:
#    Windows:  winget install PostgreSQL.PostgreSQL
#    Mac:      brew install postgresql && brew services start postgresql
#    Linux:    sudo apt install postgresql && sudo systemctl start postgresql
#
# 2. Create the database and user (run in psql):
#
#    CREATE USER kerno_dev WITH PASSWORD 'kerno_dev';
#    CREATE DATABASE kerno_dev OWNER kerno_dev;
#    GRANT ALL PRIVILEGES ON DATABASE kerno_dev TO kerno_dev;
#
# 3. Copy this file and install dependencies:
#
#    cp .env.example .env
#    pip install -e ".[dev]"
#
# 4. Run migrations:
#
#    alembic upgrade head
#
# 5. Seed dev login credentials (admin@kerno.local / changeme123) plus one user
#    per RBAC role ({role}@kerno.local / $DEV_SEED_PASSWORD, see below):
#
#    PYTHONPATH=. python scripts/seed_dev_tenant.py
#
# 6. Generate a JWT secret and paste it into .env:
#
#    python -c "import secrets; print(secrets.token_hex(32))"
#
# 7. Start the server:
#
#    uvicorn src.api.app:app --reload --port 8000
#
# 8. Open http://localhost:8000/dashboard/login.html
#    Email:    admin@kerno.local
#    Password: changeme123
#
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string — matches the user/database created in step 2 above
DATABASE_URL=postgresql://kerno_dev:kerno_dev@localhost:5432/kerno_dev

# URL for the external embedding model API
EMBEDDING_API_URL=https://your-embedding-api.example.com/v1/embeddings

# API key for the embedding model service
EMBEDDING_API_KEY=your-embedding-api-key-here

# Runtime environment — must be one of: development, staging, production
# Required to run scripts/seed_dev_tenant.py — that script refuses unless this is
# 'development'. Never set KERNO_ENV=development in a staging or production deployment.
KERNO_ENV=development

# Password for the per-role dev users seeded by scripts/seed_dev_tenant.py (KER-202).
# The seed script creates one login per RBAC role — compliance_lead@kerno.local,
# security_engineer@kerno.local, vciso@kerno.local, auditor@kerno.local,
# platform_engineer@kerno.local, end_customer_admin@kerno.local — all using this
# password. If unset, per-role user seeding is skipped. Dev-only; change freely.
DEV_SEED_PASSWORD=changeme-dev-only

# HS256 secret for signing and verifying JWTs — generate with step 6 above
KERNO_JWT_SECRET=generate-with-python-secrets-token-hex-32

# Mistral AI (EU-native LLM provider — https://console.mistral.ai)
# Replaces OpenAI. Mistral AI SAS is incorporated in France with no US-jurisdiction exposure.
MISTRAL_API_KEY=your_key_here
KERNO_LLM_MODEL=mistral-large-latest

# Jira connection for remediation task routing (KER-110)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_API_TOKEN=your_jira_token_here
JIRA_PROJECT_KEY=KERNO

# Version stamp embedded in evidence pack exports (KER-111)
KERNO_VERSION=dev

# Logging verbosity (optional — defaults to INFO)
LOG_LEVEL=INFO
